{
  "apiProvider": "openai",
  "model": "gpt-4-turbo-preview",
  "maxTokens": 2000,
  "temperature": 0.3,
  "language": "en",
  "includeSuggestions": true,
  "severityLevels": ["error", "warning", "suggestion"],
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "*.min.js",
    "*.min.css"
  ]
}

